generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserKind {
  customer
  admin
}

enum UserStatus {
  active
  invited
  suspended
  archived
}

enum ServiceAccountStatus {
  active
  disabled
}

enum OutboxStatus {
  pending
  running
  sent
  retry_wait
  failed
  cancelled
}

enum ErpSyncStatus {
  pending
  running
  retry_wait
  succeeded
  failed
  cancelled
}

enum ErpSyncJobType {
  order_create
  customer_sync
  inventory_release
}

enum PaymentSessionStatus {
  pending
  paid
  failed
  expired
}

enum OrderStatus {
  paid
  processing
  fulfilled
  cancelled
}

enum FulfillmentType {
  pickup
  delivery
}

enum InventoryReservationStatus {
  active
  released
  consumed
  expired
}

enum DealerStatus {
  active
  inactive
}

enum CatalogItemStatus {
  draft
  active
  archived
}

enum PriceStatus {
  draft
  active
  archived
}

enum PromotionStatus {
  draft
  active
  archived
}

enum ContactLeadStatus {
  new
  routed
  closed
  spam
}

enum DealerApplicationStatus {
  submitted
  under_review
  approved
  rejected
  archived
}

enum ProductReviewStatus {
  pending
  published
  rejected
  archived
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  kind               UserKind
  status             UserStatus          @default(active)
  emailVerifiedAt    DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  adminProfile       AdminProfile?
  auditLogs          AuditLog[]
  authIdentities     AuthIdentity[]
  addresses          CustomerAddress[]
  carts              Cart[]
  customerProfile    CustomerProfile?
  erpCustomerLinks   ErpCustomerLink[]
  loginEvents        LoginEvent[]
  passwordCredential PasswordCredential?
  paymentSessions    PaymentSession[]
  orders             Order[]
  favorites          Favorite[]
  refreshSessions    RefreshSession[]
  userRoles          UserRole[]

  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  slug        String     @unique
  name        String
  description String?
  parentId    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@map("categories")
}

model Product {
  id               String                 @id @default(uuid())
  slug             String                 @unique
  name             String
  shortDescription String?
  description      String?
  status           CatalogItemStatus      @default(draft)
  categoryId       String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  assets           ProductAsset[]
  category         Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reviews          ProductReview[]
  favorites        Favorite[]
  skus             PlatformSku[]
  specifications   ProductSpecification[]

  @@index([status, categoryId])
  @@map("products")
}

model PlatformSku {
  id                    String                 @id @default(uuid())
  productId             String
  skuCode               String                 @unique
  name                  String
  status                CatalogItemStatus      @default(active)
  attributes            Json?
  sortOrder             Int                    @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  assets                ProductAsset[]
  erpMappings           ProductSkuErpMapping[]
  prices                Price[]
  cartItems             CartItem[]
  inventoryReservations InventoryReservation[]
  inventorySnapshots    InventorySnapshot[]
  orderItems            OrderItem[]
  product               Product                @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, skuCode])
  @@map("platform_skus")
}

model Cart {
  id         String     @id @default(uuid())
  userId     String?    @unique
  guestToken String?    @unique
  currency   String     @default("CAD")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      CartItem[]
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String      @id @default(uuid())
  cartId    String
  skuId     String
  quantity  Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  cart      Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  sku       PlatformSku @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@unique([cartId, skuId])
  @@map("cart_items")
}

model InventorySnapshot {
  id               String          @id @default(uuid())
  skuId            String
  dealerLocationId String?
  quantityOnHand   Int             @default(0)
  quantityReserved Int             @default(0)
  updatedAt        DateTime        @default(now())
  dealerLocation   DealerLocation? @relation(fields: [dealerLocationId], references: [id], onDelete: SetNull)
  sku              PlatformSku     @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([skuId, dealerLocationId])
  @@map("inventory_snapshots")
}

model InventoryReservation {
  id               String                     @id @default(uuid())
  skuId            String
  dealerLocationId String?
  paymentSessionId String?
  ownerToken       String?
  quantity         Int
  status           InventoryReservationStatus @default(active)
  expiresAt        DateTime
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  dealerLocation   DealerLocation?            @relation(fields: [dealerLocationId], references: [id], onDelete: SetNull)
  sku              PlatformSku                @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([status, expiresAt])
  @@map("inventory_reservations")
}

model PaymentSession {
  id                String               @id @default(uuid())
  userId            String?
  guestEmail        String
  guestOrderToken   String
  status            PaymentSessionStatus @default(pending)
  fulfillment       FulfillmentType
  dealerLocationId  String?
  items             Json
  subtotalCents     Int
  taxCents          Int                  @default(0)
  shippingCents     Int                  @default(0)
  totalCents        Int
  currency          String               @default("CAD")
  providerPaymentId String?              @unique
  expiresAt         DateTime
  paidAt            DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  order             Order?
  user              User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, expiresAt])
  @@map("payment_sessions")
}

model Order {
  id               String          @id @default(uuid())
  userId           String?
  email            String
  guestOrderToken  String
  paymentSessionId String          @unique
  status           OrderStatus     @default(paid)
  fulfillment      FulfillmentType
  dealerLocationId String?
  subtotalCents    Int
  taxCents         Int             @default(0)
  shippingCents    Int             @default(0)
  totalCents       Int
  currency         String          @default("CAD")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            OrderItem[]
  statusEvents     OrderStatusEvent[]
  paymentSession   PaymentSession  @relation(fields: [paymentSessionId], references: [id], onDelete: Restrict)
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@map("orders")
}

model OrderItem {
  id             String       @id @default(uuid())
  orderId        String
  skuId          String?
  skuCode        String
  productName    String
  quantity       Int
  unitPriceCents Int
  lineTotalCents Int
  currency       String       @default("CAD")
  createdAt      DateTime     @default(now())
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku            PlatformSku? @relation(fields: [skuId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusEvent {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  source    String
  payload   Json?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_status_events")
}

model ProductAsset {
  id        String       @id @default(uuid())
  productId String
  skuId     String?
  url       String
  altText   String?
  kind      String       @default("image")
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       PlatformSku? @relation(fields: [skuId], references: [id], onDelete: SetNull)

  @@unique([productId, url])
  @@map("product_assets")
}

model ProductSpecification {
  id        String   @id @default(uuid())
  productId String
  key       String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@map("product_specifications")
}

model Price {
  id             String      @id @default(uuid())
  key            String      @unique
  skuId          String
  currency       String      @default("CAD")
  amountCents    Int
  compareAtCents Int?
  status         PriceStatus @default(active)
  effectiveFrom  DateTime?
  effectiveUntil DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  sku            PlatformSku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([status, currency])
  @@map("prices")
}

model Promotion {
  id            String          @id @default(uuid())
  key           String          @unique
  name          String
  description   String?
  discountLabel String?
  status        PromotionStatus @default(draft)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status, startsAt, endsAt])
  @@map("promotions")
}

model ContactLead {
  id               String            @id @default(uuid())
  name             String
  email            String
  phone            String?
  topic            String
  city             String?
  preferredDealer  String?
  orderNumber      String?
  message          String
  sourcePath       String?
  status           ContactLeadStatus @default(new)
  assignedToUserId String?
  assignedDealerId String?
  rawPayload       Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  notes            ContactLeadNote[]

  @@index([status, createdAt])
  @@map("contact_leads")
}

model ContactLeadNote {
  id            String      @id @default(uuid())
  contactLeadId String
  authorUserId  String?
  note          String
  createdAt     DateTime    @default(now())
  contactLead   ContactLead @relation(fields: [contactLeadId], references: [id], onDelete: Cascade)

  @@map("contact_lead_notes")
}

model DealerApplication {
  id                         String                  @id @default(uuid())
  companyName                String
  contactName                String
  email                      String
  phone                      String
  website                    String?
  businessType               String?
  city                       String
  province                   String
  serviceArea                String?
  productFocus               String?
  capabilities               Json?
  message                    String?
  source                     String?
  applicationAcknowledgement Boolean                 @default(false)
  status                     DealerApplicationStatus @default(submitted)
  rawPayload                 Json?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  notes                      DealerApplicationNote[]

  @@index([status, createdAt])
  @@map("dealer_applications")
}

model DealerApplicationNote {
  id                  String            @id @default(uuid())
  dealerApplicationId String
  authorUserId        String?
  note                String
  createdAt           DateTime          @default(now())
  dealerApplication   DealerApplication @relation(fields: [dealerApplicationId], references: [id], onDelete: Cascade)

  @@map("dealer_application_notes")
}

model ProductReview {
  id            String              @id @default(uuid())
  productId     String
  rating        Int
  title         String?
  body          String
  nickname      String
  email         String
  topics        Json?
  acceptedTerms Boolean             @default(false)
  status        ProductReviewStatus @default(pending)
  moderatedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  notes         ProductReviewNote[]
  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, status, createdAt])
  @@index([status, createdAt])
  @@map("product_reviews")
}

model ProductReviewNote {
  id              String        @id @default(uuid())
  productReviewId String
  authorUserId    String?
  note            String
  createdAt       DateTime      @default(now())
  productReview   ProductReview @relation(fields: [productReviewId], references: [id], onDelete: Cascade)

  @@map("product_review_notes")
}

model ProductSkuErpMapping {
  id        String      @id @default(uuid())
  skuId     String
  erpSystem String
  erpSkuKey String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  sku       PlatformSku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([skuId, erpSystem])
  @@unique([erpSystem, erpSkuKey])
  @@map("product_sku_erp_mappings")
}

model CustomerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  firstName String?
  lastName  String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model CustomerAddress {
  id           String   @id @default(uuid())
  userId       String
  label        String?
  firstName    String
  lastName     String
  phone        String?
  addressLine1 String
  addressLine2 String?
  city         String
  province     String
  postalCode   String
  country      String   @default("CA")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
  @@map("customer_addresses")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model AdminProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model AuthIdentity {
  id             String   @id @default(uuid())
  userId         String
  provider       String
  providerUserId String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("auth_identities")
}

model PasswordCredential {
  id           String   @id @default(uuid())
  userId       String   @unique
  algorithm    String
  passwordHash String
  passwordSalt String
  iterations   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}

model RefreshSession {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_sessions")
}

model Role {
  id                  String               @id @default(uuid())
  key                 String               @unique
  name                String
  description         String?
  isSystem            Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  rolePermissions     RolePermission[]
  serviceAccountRoles ServiceAccountRole[]
  userRoles           UserRole[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model ServiceAccount {
  id        String                @id @default(uuid())
  name      String
  key       String                @unique
  status    ServiceAccountStatus  @default(active)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  auditLogs AuditLog[]
  mcpInvocations McpToolInvocation[]
  roles     ServiceAccountRole[]
  tokens    ServiceAccountToken[]

  @@map("service_accounts")
}

model ServiceAccountRole {
  id               String         @id @default(uuid())
  serviceAccountId String
  roleId           String
  createdAt        DateTime       @default(now())
  role             Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  @@unique([serviceAccountId, roleId])
  @@map("service_account_roles")
}

model ServiceAccountToken {
  id               String         @id @default(uuid())
  serviceAccountId String
  tokenHash        String         @unique
  name             String?
  lastUsedAt       DateTime?
  expiresAt        DateTime?
  revokedAt        DateTime?
  createdAt        DateTime       @default(now())
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  @@map("service_account_tokens")
}

model McpToolInvocation {
  id               String         @id @default(uuid())
  serviceAccountId String
  toolKey          String
  status           String
  input            Json?
  output           Json?
  error            String?
  createdAt        DateTime       @default(now())
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  @@index([serviceAccountId, createdAt])
  @@map("mcp_tool_invocations")
}

model LoginEvent {
  id        String   @id @default(uuid())
  userId    String?
  email     String?
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("login_events")
}

model AuditLog {
  id               String          @id @default(uuid())
  actorUserId      String?
  serviceAccountId String?
  action           String
  resourceType     String
  resourceId       String?
  metadata         Json?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime        @default(now())
  actorUser        User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  serviceAccount   ServiceAccount? @relation(fields: [serviceAccountId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model PrivacyConsentEvent {
  id          String   @id @default(uuid())
  anonymousId String
  preferences Json
  source      String
  createdAt   DateTime @default(now())

  @@index([anonymousId, createdAt])
  @@map("privacy_consent_events")
}

model Dealer {
  id        String           @id @default(uuid())
  code      String           @unique
  name      String
  status    DealerStatus     @default(active)
  phone     String?
  email     String?
  website   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  erpLinks  DealerErpLink[]
  locations DealerLocation[]

  @@map("dealers")
}

model DealerLocation {
  id                    String                 @id @default(uuid())
  dealerId              String
  code                  String
  name                  String
  addressLine1          String?
  addressLine2          String?
  city                  String?
  province              String?
  postalCode            String?
  country               String                 @default("CA")
  pickupAvailable       Boolean                @default(false)
  deliveryAvailable     Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  dealer                Dealer                 @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  erpLinks              DealerErpLink[]
  serviceAreas          DealerServiceArea[]
  inventorySnapshots    InventorySnapshot[]
  inventoryReservations InventoryReservation[]

  @@unique([dealerId, code])
  @@map("dealer_locations")
}

model DealerServiceArea {
  id               String         @id @default(uuid())
  dealerLocationId String
  areaType         String
  areaCode         String
  createdAt        DateTime       @default(now())
  dealerLocation   DealerLocation @relation(fields: [dealerLocationId], references: [id], onDelete: Cascade)

  @@unique([dealerLocationId, areaType, areaCode])
  @@map("dealer_service_areas")
}

model DealerErpLink {
  id               String          @id @default(uuid())
  dealerId         String
  dealerLocationId String?
  erpSystem        String
  erpLocationId    String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  dealer           Dealer          @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  dealerLocation   DealerLocation? @relation(fields: [dealerLocationId], references: [id], onDelete: SetNull)

  @@unique([erpSystem, erpLocationId])
  @@map("dealer_erp_links")
}

model EmailTemplate {
  id        String                 @id @default(uuid())
  key       String                 @unique
  name      String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  versions  EmailTemplateVersion[]

  @@map("email_templates")
}

model EmailTemplateVersion {
  id          String        @id @default(uuid())
  templateId  String
  version     Int
  subject     String
  bodyText    String?
  bodyHtml    String?
  isPublished Boolean       @default(false)
  createdAt   DateTime      @default(now())
  template    EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@map("email_template_versions")
}

model EmailOutbox {
  id           String                 @id @default(uuid())
  templateKey  String?
  toEmail      String
  subject      String?
  payload      Json?
  status       OutboxStatus           @default(pending)
  attemptCount Int                    @default(0)
  lastError    String?
  nextRunAt    DateTime?
  lockedBy     String?
  lockedAt     DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  attempts     EmailDeliveryAttempt[]
  events       EmailEvent[]

  @@index([status, nextRunAt])
  @@map("email_outbox")
}

model EmailDeliveryAttempt {
  id            String      @id @default(uuid())
  emailOutboxId String
  provider      String?
  success       Boolean
  error         String?
  createdAt     DateTime    @default(now())
  emailOutbox   EmailOutbox @relation(fields: [emailOutboxId], references: [id], onDelete: Cascade)

  @@map("email_delivery_attempts")
}

model EmailEvent {
  id            String      @id @default(uuid())
  emailOutboxId String
  eventType     String
  payload       Json?
  createdAt     DateTime    @default(now())
  emailOutbox   EmailOutbox @relation(fields: [emailOutboxId], references: [id], onDelete: Cascade)

  @@map("email_events")
}

model EmailSuppressionList {
  id        String   @id @default(uuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())

  @@map("email_suppression_list")
}

model EmailProviderAccount {
  id        String   @id @default(uuid())
  key       String   @unique
  provider  String
  status    String   @default("disabled")
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_provider_accounts")
}

model ErpSyncJob {
  id           String           @id @default(uuid())
  type         ErpSyncJobType
  status       ErpSyncStatus    @default(pending)
  payload      Json
  externalId   String?
  attemptCount Int              @default(0)
  lastError    String?
  nextRunAt    DateTime?
  lockedBy     String?
  lockedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  attempts     ErpSyncAttempt[]

  @@index([status, nextRunAt])
  @@map("erp_sync_jobs")
}

model ErpSyncAttempt {
  id           String     @id @default(uuid())
  erpSyncJobId String
  success      Boolean
  error        String?
  request      Json?
  response     Json?
  createdAt    DateTime   @default(now())
  erpSyncJob   ErpSyncJob @relation(fields: [erpSyncJobId], references: [id], onDelete: Cascade)

  @@map("erp_sync_attempts")
}

model ErpCustomerLink {
  id             String   @id @default(uuid())
  customerUserId String?
  websiteEmail   String?
  erpCustomerId  String
  erpSystem      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  customerUser   User?    @relation(fields: [customerUserId], references: [id], onDelete: SetNull)

  @@unique([erpSystem, erpCustomerId])
  @@map("erp_customer_links")
}

model ErpOrderLink {
  id             String   @id @default(uuid())
  websiteOrderId String   @unique
  erpOrderId     String
  erpSystem      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([erpSystem, erpOrderId])
  @@map("erp_order_links")
}

model ErpWebhookEvent {
  id          String    @id @default(uuid())
  erpSystem   String
  eventType   String
  externalId  String?
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@unique([erpSystem, eventType, externalId])

  @@map("erp_webhook_events")
}
